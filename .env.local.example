# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://keihzjpkshrucqwiwzoy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your@email.com

# Daily report PDF + LINE delivery
DAILY_REPORTS_BUCKET=daily-reports
LINE_DAILY_REPORT_NOTIFY_TOKEN=your-line-notify-token
# Or use LINE Messaging API instead of Notify:
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_DAILY_REPORT_TO=owner-line-user-id-or-group-id

# Anthropic Claude (OCR receipt reading)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Cloud Vision (legacy - replaced by Claude)
# GOOGLE_CLOUD_VISION_KEY=base64-encoded-service-account-json

# App
NEXT_PUBLIC_APP_URL=https://your-vercel-url.vercel.app
